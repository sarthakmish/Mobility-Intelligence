# ============================================================
# MOBILITY SOLUTIONS INTELLIGENCE — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
# NEVER commit .env to git — it contains secrets!
# ============================================================

# ── DATABASE ──────────────────────────────────────────────
POSTGRES_USER=mobility
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=mobility_intelligence
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://mobility:changeme_in_production@postgres:5432/mobility_intelligence

# ── REDIS ─────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── LLM FARM — All models via Bosch proxy ────────────────
# One key, one domain for Claude Sonnet, Haiku, GPT-5 mini, and embeddings.
# Get your key from the LLM Farm portal / your team's subscription.
LLM_FARM_API_KEY=your_llm_farm_api_key_here
LLM_FARM_BASE_URL=https://aoai-farm.bosch-temp.com

# GPT-5 mini Azure deployment name (Azure OpenAI style)
LLM_FARM_GPT_DEPLOYMENT=gpt-5-mini-2025-08-07
# Embedding deployment name
LLM_FARM_EMBEDDING_DEPLOYMENT=askbosch-prod-farm-openai-text-embedding-3-small

# ── LLM MODEL CONFIGURATION ──────────────────────────────
# Primary model: C-suite analysis, PESTEL scoring, reports
PRIMARY_MODEL=claude-sonnet-4-6
# Validation model: Cross-checking, structured scoring
VALIDATOR_MODEL=claude-haiku-4-5
# Fallback if primary is down
PRIMARY_FALLBACK_MODEL=claude-sonnet-4-5
# Volume model: News sentiment, trend detection (batch)
VOLUME_MODEL=gpt-5-mini
# Embedding model
EMBEDDING_MODEL=text-embedding-3-small

# ── REFRESH SCHEDULE ──────────────────────────────────────
# How often (in hours) the system auto-refreshes data
# Default: every 6 hours. Range: 1-24
AUTO_REFRESH_HOURS=6

# ── API CONFIGURATION ────────────────────────────────────
# CORS origins — your Vercel frontend URL
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app
API_HOST=0.0.0.0
API_PORT=8000

# ── CACHE TTL (in seconds) ───────────────────────────────
# How long AI-generated analysis stays cached
ANALYSIS_CACHE_TTL=14400   # 4 hours
PESTEL_CACHE_TTL=21600     # 6 hours
TECH_CACHE_TTL=21600       # 6 hours

# ── EUR/USD CONVERSION ───────────────────────────────────
EUR_USD_RATE=0.92
